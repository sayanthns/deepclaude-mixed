{
  "name": "deepclaude-mixed",
  "displayName": "DeepClaude Mixed",
  "description": "DeepSeek proxy for Claude Code + Frappe Brain MCP config. One extension, zero env var setup.",
  "version": "0.1.4",
  "publisher": "ENfono",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sayanthns/deepclaude-mixed"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepclaude-mixed.setApiKey",
        "title": "Set DeepSeek API Key"
      },
      {
        "command": "deepclaude-mixed.restartProxy",
        "title": "Restart Proxy"
      },
      {
        "command": "deepclaude-mixed.showStatus",
        "title": "Show Proxy Status"
      },
      {
        "command": "deepclaude-mixed.toggleMode",
        "title": "Toggle 1p/3p Mode"
      },
      {
        "command": "deepclaude-mixed.configureBrain",
        "title": "Frappe Brain: Configure"
      },
      {
        "command": "deepclaude-mixed.enableBrain",
        "title": "Frappe Brain: Enable"
      },
      {
        "command": "deepclaude-mixed.disableBrain",
        "title": "Frappe Brain: Disable"
      },
      {
        "command": "deepclaude-mixed.toggleBrain",
        "title": "Frappe Brain: Toggle"
      },
      {
        "command": "deepclaude-mixed.brainStatus",
        "title": "Frappe Brain: Show Status"
      }
    ],
    "configuration": {
      "title": "DeepClaude Mixed",
      "properties": {
        "deepclaude-mixed.proxyPort": {
          "type": "number",
          "default": 3200,
          "description": "Local port for the proxy (127.0.0.1)"
        },
        "deepclaude-mixed.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start proxy automatically when VS Code starts"
        },
        "deepclaude-mixed.healthPollIntervalSec": {
          "type": "number",
          "default": 30,
          "description": "Seconds between health check polls (10-300)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
